---
import { getCollection, render, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import ServicesLayout from "@layouts/ServicesLayout.astro";
import InfoCard from "@ui/InfoCard.astro";
import TableOfContentsList from "@ui/TableOfContentsList.astro";
import { getServiceImage } from "@data/service-images";
import { getContentSlug, getTocItems, hasItems } from "@lib/content";

export async function getStaticPaths() {
  const services = await getCollection(
    "services",
    ({ data }) => data.status === "active",
  );

  return services.map((service) => ({
    params: { slug: getContentSlug(service.id) },
    props: { service },
  }));
}

type ServiceEntry = CollectionEntry<"services">;

const { service } = Astro.props as { service: ServiceEntry };
const { Content, headings } = await render(service);
const tocItems = getTocItems(headings);
const hasToc = hasItems(tocItems);
const slug = getContentSlug(service.id);
const selectedImage = getServiceImage(slug);
const selectedImageAlt =
  service.data.heroAlt ??
  `Imagen referencial del servicio ${service.data.title} de AgroChoco`;
---

<ServicesLayout
  title={service.data.title}
  description={service.data.excerpt ?? service.data.description}
  category={service.data.category}
  duration={service.data.duration}
>
  <section class="mb-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <InfoCard label="Categoría" value={service.data.category} />
    <InfoCard label="Duración" value={service.data.duration ?? "Por definir"} />
    <InfoCard
      label="Beneficios"
      value={`${service.data.benefits.length} resultados`}
    />
  </section>

  <div class="grid items-start gap-8 lg:grid-cols-12 lg:gap-10 xl:gap-12">
    <div class="space-y-6 lg:col-span-8">
      <figure
        class="overflow-hidden rounded-2xl border border-emerald-100 bg-white shadow-sm sm:rounded-3xl"
      >
        <Image
          src={selectedImage}
          alt={selectedImageAlt}
          widths={[640, 960, 1280]}
          sizes="(min-width: 1280px) 52rem, (min-width: 1024px) 66vw, 100vw"
          loading="eager"
          class="h-56 w-full object-cover sm:h-64 md:h-72"
        />
      </figure>

      <article class="prose-content">
        <Content />
      </article>

      <section
        class="rounded-2xl border border-emerald-200 bg-linear-to-r from-emerald-50 to-teal-50 p-6 shadow-sm sm:rounded-3xl sm:p-8"
      >
        <h2 class="text-2xl font-bold text-emerald-900">
          Contacta al equipo técnico
        </h2>
        <p
          class="mt-3 max-w-3xl text-sm leading-relaxed text-emerald-900/80 sm:text-base"
        >
          Si quieres implementar este servicio en tu cultivo, agenda una
          conversación con AgroChoco para revisar alcance, tiempos y resultados
          esperados según tus condiciones productivas.
        </p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a
            href="/#contacto"
            class="inline-flex items-center justify-center rounded-full bg-emerald-700 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-emerald-800"
          >
            Ir al formulario de contacto
          </a>
          <a
            href={`https://wa.me/?text=${encodeURIComponent(`Hola AgroChoco, me interesa el servicio ${service.data.title}. Quiero más información.`)}`}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center rounded-full border border-emerald-300 bg-white px-5 py-2.5 text-sm font-semibold text-emerald-800 transition-colors hover:bg-emerald-50"
          >
            Contactar por WhatsApp
          </a>
        </div>
      </section>
    </div>

    <aside class="space-y-6 lg:sticky lg:top-24 lg:col-span-4">
      <div class="rounded-2xl border border-emerald-100 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-emerald-900">
          Especificaciones clave
        </h2>
        {
          service.data.specifications.length > 0 ? (
            <ul class="mt-4 space-y-2 text-sm text-gray-700">
              {service.data.specifications.map((item) => (
                <li class="rounded-lg bg-emerald-50/70 px-3 py-2">{item}</li>
              ))}
            </ul>
          ) : (
            <p class="mt-4 text-sm text-gray-500">
              Este servicio no tiene especificaciones publicadas.
            </p>
          )
        }
      </div>

      {
        hasToc && (
          <div class="rounded-2xl border border-emerald-100 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-bold text-emerald-900">En esta página</h2>
            <TableOfContentsList items={tocItems} />
          </div>
        )
      }
    </aside>
  </div>
</ServicesLayout>
