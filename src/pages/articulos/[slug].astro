---
import { getCollection, render, type CollectionEntry } from "astro:content";
import LandingLayout from "@layouts/LandingLayout.astro";
import Icon from "@ui/Icon.astro";
import TableOfContentsList from "@ui/TableOfContentsList.astro";
import agrochocoLogo from "@images/branding/agrochoco-logo.svg";
import {
  estimateReadingMinutes,
  getContentSlug,
  getTocItems,
  hasItems,
} from "@lib/content";
import {
  globalPlaceholderImageAlt,
  globalPlaceholderImage,
} from "../../data/media";

type ArticleEntry = CollectionEntry<"articles">;

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: { slug: getContentSlug(article.id) },
    props: { article },
  }));
}

const { article } = Astro.props as { article: ArticleEntry };
const { Content, headings } = await render(article);

const pageTitle = article.data.title;
const pageDescription = article.data.excerpt ?? article.data.description;
const tocItems = getTocItems(headings);
const readingMinutes = estimateReadingMinutes(article.body ?? "");
const hasToc = hasItems(tocItems);
const publishedDate = new Intl.DateTimeFormat("es-CO", {
  day: "numeric",
  month: "short",
  year: "numeric",
}).format(new Date());
---

<LandingLayout title={pageTitle} description={pageDescription}>
  <section
    transition:name="article-hero"
    transition:animate="fade"
    class="relative overflow-hidden bg-linear-to-b from-emerald-950 via-emerald-900 to-emerald-800 pt-28 pb-10 text-white sm:pt-32 sm:pb-12 lg:pt-36"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 [background:radial-gradient(90%_70%_at_90%_0%,rgba(16,185,129,0.23)_0%,rgba(6,78,59,0)_60%)]"
    >
    </div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <a
        href="/#nosotros"
        class="inline-flex items-center gap-2 rounded-full border border-white/35 px-4 py-2 text-sm font-medium text-white/90 transition-colors hover:bg-white/10"
      >
        <Icon name="arrow-left" className="h-4 w-4" />
        Volver al inicio
      </a>

      <div class="mt-8 max-w-4xl space-y-5">
        <div class="flex flex-wrap items-center gap-2.5 text-xs sm:text-sm">
          <span
            class="rounded-full border border-emerald-300/35 bg-emerald-400/10 px-3 py-1 font-semibold tracking-wide text-emerald-100 uppercase"
          >
            {article.data.category}
          </span>
          <span
            class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-white/85"
          >
            {readingMinutes} min de lectura
          </span>
        </div>

        <h1
          class="font-display text-3xl leading-tight font-extrabold sm:text-4xl md:text-5xl"
        >
          {article.data.title}
        </h1>

        <p
          class="max-w-3xl text-base leading-relaxed text-emerald-100/95 sm:text-lg"
        >
          {article.data.description}
        </p>
      </div>
    </div>
  </section>

  <section
    transition:animate="fade"
    class="relative overflow-hidden bg-linear-to-b from-emerald-50/70 via-white to-white py-8 sm:py-10 lg:py-12"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-10 right-32 h-52 w-52 rounded-full bg-emerald-200/35 blur-3xl"
    >
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute bottom-8 left-32 h-56 w-56 rounded-full bg-amber-200/30 blur-3xl"
    >
    </div>
    <div class="mx-auto max-w-screen-xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-8 lg:grid-cols-12 lg:gap-10 xl:gap-12">
        <div class="space-y-6 sm:space-y-8 lg:col-span-8">
          <header
            class="not-format rounded-2xl border border-emerald-100 bg-white px-5 py-5 shadow-sm sm:rounded-3xl sm:px-7"
          >
            <address class="flex items-center gap-4 not-italic">
              <img
                src={agrochocoLogo.src}
                alt="AgroChoco"
                class="h-12 w-12 rounded-full border border-emerald-100 bg-white p-2"
                loading="lazy"
                decoding="async"
              />
              <div>
                <p class="text-base font-bold text-gray-900">
                  Equipo AgroChoco
                </p>
                <p class="text-sm text-gray-500">
                  Investigación y desarrollo agrícola
                </p>
                <p class="text-sm text-gray-500">
                  <time datetime={new Date().toISOString()}
                    >{publishedDate}</time
                  >
                  <span class="mx-2">•</span>
                  {readingMinutes} min de lectura
                </p>
              </div>
            </address>
          </header>

          <figure
            class="overflow-hidden rounded-2xl border border-emerald-100 bg-white shadow-sm sm:rounded-3xl sm:shadow-lg"
          >
            <img
              src={globalPlaceholderImage}
              alt={globalPlaceholderImageAlt}
              class="h-56 w-full object-cover sm:h-72 md:h-96"
              loading="lazy"
              decoding="async"
            />
          </figure>

          {
            hasToc && (
              <details class="rounded-2xl border border-emerald-100 bg-white p-5 shadow-xs lg:hidden">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-emerald-900 [&::-webkit-details-marker]:hidden [&::marker]:content-['']">
                  En este artículo
                  <Icon
                    name="chevron-down"
                    className="w-4 h-4 text-emerald-700"
                  />
                </summary>
                <TableOfContentsList
                  items={tocItems}
                  listClass="mt-4 space-y-2.5"
                />
              </details>
            )
          }

          <article
            class="format format-sm sm:format-base lg:format-lg prose-content"
          >
            <Content />
          </article>
        </div>

        <aside class="hidden lg:sticky lg:top-28 lg:col-span-4 lg:block">
          <div
            class="rounded-2xl border border-emerald-100 bg-white p-6 shadow-sm"
          >
            <h2 class="text-lg font-bold text-emerald-900">En este artículo</h2>
            {
              hasToc ? (
                <TableOfContentsList items={tocItems} />
              ) : (
                <p class="mt-4 text-sm text-gray-500">
                  Contenido introductorio disponible en una sola sección.
                </p>
              )
            }
          </div>
        </aside>
      </div>
    </div>
  </section>
</LandingLayout>
