---
import { Picture } from "astro:assets";
import { getCollection, render, type CollectionEntry } from "astro:content";
import LandingLayout from "@layouts/LandingLayout.astro";
import Icon from "@ui/Icon.astro";
import {
    globalPlaceholderImageAlt,
    globalPlaceholderImage,
} from "../../data/media";

type ArticleEntry = CollectionEntry<"articles">;

export async function getStaticPaths() {
    const articles = await getCollection("articles");

    return articles.map((article) => ({
        params: { slug: article.id.replace(/\.md$/, "") },
        props: { article },
    }));
}

const { article } = Astro.props as { article: ArticleEntry };
const { Content, headings } = await render(article);

const pageTitle = article.data.title;
const pageDescription = article.data.excerpt ?? article.data.description;
const tocItems = headings.filter((heading) => heading.depth === 2);
const wordCount = (article.body ?? "").split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 180));
const hasToc = tocItems.length > 0;
---

<LandingLayout title={pageTitle} description={pageDescription}>
    <section
        transition:name="article-hero"
        transition:animate="fade"
        class="relative overflow-hidden pt-28 sm:pt-32 lg:pt-36 pb-10 sm:pb-12 bg-linear-to-b from-emerald-950 via-emerald-900 to-emerald-800 text-white"
    >
        <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-0 [background:radial-gradient(90%_70%_at_90%_0%,rgba(16,185,129,0.23)_0%,rgba(6,78,59,0)_60%)]"
        >
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <a
                href="/#nosotros"
                class="inline-flex items-center gap-2 rounded-full border border-white/35 px-4 py-2 text-sm font-medium text-white/90 transition-colors hover:bg-white/10"
            >
                <Icon name="arrow-left" className="w-4 h-4" />
                Volver al inicio
            </a>

            <div class="mt-8 max-w-4xl space-y-5">
                <div
                    class="flex flex-wrap items-center gap-2.5 text-xs sm:text-sm"
                >
                    <span
                        class="rounded-full border border-emerald-300/35 bg-emerald-400/10 px-3 py-1 font-semibold tracking-wide uppercase text-emerald-100"
                    >
                        {article.data.category}
                    </span>
                    <span
                        class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-white/85"
                    >
                        {readingMinutes} min de lectura
                    </span>
                </div>

                <h1
                    class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold leading-tight"
                >
                    {article.data.title}
                </h1>

                <p
                    class="text-base sm:text-lg text-emerald-100/95 leading-relaxed max-w-3xl"
                >
                    {article.data.description}
                </p>
            </div>
        </div>
    </section>

    <section
        transition:animate="fade"
        class="relative overflow-hidden py-8 sm:py-10 lg:py-12 bg-linear-to-b from-emerald-50/70 via-white to-white"
    >
        <div
            aria-hidden="true"
            class="pointer-events-none absolute -top-10 right-32 h-52 w-52 rounded-full bg-emerald-200/35 blur-3xl"
        >
        </div>
        <div
            aria-hidden="true"
            class="pointer-events-none absolute bottom-8 left-32 h-56 w-56 rounded-full bg-amber-200/30 blur-3xl"
        >
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div
                class="grid lg:grid-cols-12 gap-8 lg:gap-10 xl:gap-12 items-start"
            >
                <div class="lg:col-span-8 space-y-6 sm:space-y-8">
                    <figure
                        class="overflow-hidden rounded-2xl sm:rounded-3xl border border-emerald-100 bg-white shadow-sm sm:shadow-lg"
                    >
                        <Picture
                            src={globalPlaceholderImage}
                            formats={["avif", "webp"]}
                            alt={globalPlaceholderImageAlt}
                            class="w-full h-56 sm:h-72 md:h-96 object-cover"
                            loading="lazy"
                            decoding="async"
                        />
                    </figure>

                    {
                        hasToc && (
                            <details class="lg:hidden rounded-2xl border border-emerald-100 bg-white p-5 shadow-xs">
                                <summary class="cursor-pointer list-none flex items-center justify-between gap-4 font-semibold text-emerald-900 [&::-webkit-details-marker]:hidden [&::marker]:content-['']">
                                    En este articulo
                                    <Icon
                                        name="chevron-down"
                                        className="w-4 h-4 text-emerald-700"
                                    />
                                </summary>
                                <ul class="mt-4 space-y-2.5">
                                    {tocItems.map((item) => (
                                        <li>
                                            <a
                                                href={`#${item.slug}`}
                                                class="text-sm text-gray-600 hover:text-emerald-700 transition-colors"
                                            >
                                                {item.text}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </details>
                        )
                    }

                    <article
                        class="rounded-2xl sm:rounded-3xl border border-emerald-100/70 bg-white px-5 py-6 sm:px-7 sm:py-8 md:px-10 md:py-10 shadow-sm text-gray-700 leading-7 sm:leading-8 [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-xl sm:[&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-emerald-900 [&_h3]:mt-7 [&_h3]:mb-3 [&_h3]:text-lg sm:[&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-gray-900 [&_p]:mb-4 [&_ul]:mb-5 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:mb-5 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:mb-2 [&_blockquote]:my-6 [&_blockquote]:rounded-xl [&_blockquote]:border-l-4 [&_blockquote]:border-emerald-500 [&_blockquote]:bg-emerald-50/60 [&_blockquote]:px-5 [&_blockquote]:py-3 [&_blockquote]:text-emerald-900 [&_a]:text-emerald-700 hover:[&_a]:text-emerald-800 [&_a]:underline [&_code]:rounded [&_code]:bg-gray-100 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-[0.95em]"
                    >
                        <Content />
                    </article>
                </div>

                <aside
                    class="hidden lg:block lg:col-span-4 lg:sticky lg:top-28"
                >
                    <div
                        class="rounded-2xl border border-emerald-100 bg-white p-6 shadow-sm"
                    >
                        <h2 class="text-lg font-bold text-emerald-900">
                            En este articulo
                        </h2>
                        {
                            hasToc ? (
                                <ul class="mt-4 space-y-3">
                                    {tocItems.map((item) => (
                                        <li>
                                            <a
                                                href={`#${item.slug}`}
                                                class="text-sm text-gray-600 hover:text-emerald-700 transition-colors"
                                            >
                                                {item.text}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            ) : (
                                <p class="mt-4 text-sm text-gray-500">
                                    Contenido introductorio disponible en una
                                    sola seccion.
                                </p>
                            )
                        }
                    </div>
                </aside>
            </div>
        </div>
    </section>
</LandingLayout>
