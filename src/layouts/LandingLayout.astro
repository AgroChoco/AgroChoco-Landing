---
import "../styles/global.css";
import Navbar from "@shared/Navbar.astro";
import SEO from "@shared/SEO.astro";
import Footer from "@shared/Footer.astro";

const {
  title = "AgroChoco",
  description = "Servicios de micropropagación in vitro, clonación de plantas, análisis de suelos y asesoría técnica agrícola para elevar productividad y sostenibilidad.",
} = Astro.props;
---

<html lang="es">
  <head>
    <SEO title={title} description={description} />
    <slot name="head" />
  </head>
  <body
    class="min-h-screen w-full overflow-x-hidden bg-gray-50 text-gray-800 antialiased"
  >
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
