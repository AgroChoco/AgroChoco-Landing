---
import LandingLayout from "@layouts/LandingLayout.astro";
import Icon from "@ui/Icon.astro";

interface Props {
    title: string;
    description: string;
    category?: string;
    duration?: string;
}

const { title, description, category = "Servicio", duration } = Astro.props;
---

<LandingLayout
    title={`${title} | Servicios AgroChoco`}
    description={description}
>
    <section
        class="relative overflow-hidden border-b border-emerald-800/70 bg-linear-to-r from-[#0f2a22] via-[#134d3e] to-[#0f2a22] pt-24 pb-10 text-white sm:pt-28 lg:pt-32"
    >
        <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-0 [background:radial-gradient(60%_60%_at_80%_10%,rgba(16,185,129,0.22)_0%,rgba(16,185,129,0)_70%)]"
        >
        </div>
        <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-linear-to-r from-lime-400 via-emerald-300 to-cyan-300"
        >
        </div>

        <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="grid gap-8 lg:grid-cols-12 lg:items-end">
                <div class="lg:col-span-8">
                    <a
                        href="/#inicio"
                        class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/5 px-4 py-2 text-sm font-medium text-white/90 transition-colors hover:bg-white/12"
                    >
                        <Icon name="arrow-left" className="h-4 w-4" />
                        Volver a inicio
                    </a>

                    <div class="mt-6 space-y-5">
                        <div
                            class="flex flex-wrap items-center gap-2.5 text-xs sm:text-sm"
                        >
                            <span
                                class="rounded-full border border-emerald-200/35 bg-emerald-300/10 px-3 py-1 font-semibold tracking-wide text-emerald-100 uppercase"
                            >
                                {category}
                            </span>
                            {
                                duration && (
                                    <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-white/85">
                                        Duración estimada: {duration}
                                    </span>
                                )
                            }
                        </div>

                        <h1
                            class="font-display text-3xl leading-tight font-extrabold tracking-tight sm:text-4xl md:text-5xl"
                        >
                            {title}
                        </h1>

                        <p
                            class="max-w-3xl text-base leading-relaxed text-emerald-100/95 sm:text-lg"
                        >
                            {description}
                        </p>
                    </div>
                </div>

                <div class="lg:col-span-4">
                    <span
                        class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/5 px-3 py-1 text-xs font-semibold tracking-wide text-white/85 uppercase"
                    >
                        <span class="h-2 w-2 rounded-full bg-lime-300"></span>
                        Servicio especializado
                    </span>
                    <p class="mt-4 text-sm leading-relaxed text-emerald-100/90">
                        Metodología guiada por evidencia de campo y laboratorio,
                        con foco en resultados medibles y transferencia técnica.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section
        class="bg-linear-to-b from-emerald-50/70 via-white to-white py-8 sm:py-10 lg:py-12"
    >
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <slot />
        </div>
    </section>
</LandingLayout>
