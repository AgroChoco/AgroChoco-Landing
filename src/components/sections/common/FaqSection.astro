---
import SectionHeading from "@ui/SectionHeading.astro";
import Icon from "@ui/Icon.astro";
import type { FaqItem } from "../../../data/faqs";

interface Props {
  id?: string;
  faqs: FaqItem[];
  allowMultiple?: boolean;
}

const { id = "preguntas", faqs, allowMultiple = false } = Astro.props;
const accordionName = `${id}-faq-accordion`;
---

<section id={id} class="relative bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Resolvemos tus dudas"
      title="Preguntas Frecuentes"
    />

    <div
      class="animate-fade-up space-y-4 [animation-delay:100ms] motion-reduce:animate-none"
    >
      {
        faqs.map((faq, index) => {
          const panelId = `faq-panel-${index + 1}`;

          return (
            <details
              class="group overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm transition-all duration-300"
              name={allowMultiple ? undefined : accordionName}
            >
              <summary class="flex w-full cursor-pointer list-none items-center justify-between px-4 py-4 text-left transition-colors hover:bg-emerald-50/50 sm:px-6 sm:py-5 [&::-webkit-details-marker]:hidden [&::marker]:content-['']">
                <span class="font-bold break-words text-gray-800">
                  {faq.question}
                </span>
                <Icon
                  name="chevron-down"
                  className="w-5 h-5 text-emerald-600 transition-transform duration-300 group-open:rotate-180"
                />
              </summary>
              <div
                id={panelId}
                class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out group-open:grid-rows-[1fr]"
                role="region"
              >
                <div class="overflow-hidden px-4 pt-2 pb-5 leading-relaxed text-gray-600 sm:px-6 sm:pb-6">
                  {faq.answer}
                </div>
              </div>
            </details>
          );
        })
      }
    </div>
  </div>
</section>
