---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { globalPlaceholderImage } from "../../../data/media";

interface StatItem {
    value: string;
    label: string;
}

interface Props {
    items?: StatItem[];
    backgroundImage?: ImageMetadata;
}

const {
    items = [
        {
            value: "100%",
            label: "Calidad genetica",
        },
        {
            value: "Sanos",
            label: "Cultivos libres de plagas",
        },
        {
            value: "Maximo",
            label: "Rendimiento productivo",
        },
    ],
    backgroundImage = globalPlaceholderImage,
} = Astro.props;
---

<section
    class="py-16 bg-linear-to-r from-emerald-800 to-teal-900 relative overflow-hidden"
>
    <div class="absolute inset-0">
        <Image
            src={backgroundImage}
            alt="Fondo agricultura"
            class="w-full h-full object-cover mix-blend-overlay opacity-30"
            loading="lazy"
            decoding="async"
        />
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div
            class="grid md:grid-cols-3 gap-8 text-center divide-y md:divide-y-0 md:divide-x divide-emerald-600/50 animate-fade-up motion-reduce:animate-none"
        >
            {
                items.map((item, index) => (
                    <div
                        class={["p-4", index === 0 ? "" : "pt-8 md:pt-4"].join(
                            " ",
                        )}
                    >
                        <div class="text-5xl font-extrabold text-white mb-2 tracking-tight">
                            {item.value}
                        </div>
                        <div class="text-emerald-200 font-medium uppercase tracking-wide text-sm">
                            {item.label}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
