---
import { statsSectionImage } from "../../../data/media";

interface StatItem {
  value: string;
  label: string;
}

interface Props {
  items?: StatItem[];
  backgroundImage?: string;
}

const {
  items = [
    {
      value: "100%",
      label: "Calidad genética",
    },
    {
      value: "Sanos",
      label: "Cultivos libres de plagas",
    },
    {
      value: "Máximo",
      label: "Rendimiento productivo",
    },
  ],
  backgroundImage = statsSectionImage,
} = Astro.props;
---

<section
  class="relative overflow-hidden bg-linear-to-r from-emerald-800 to-teal-900 py-14 sm:py-16"
>
  <div class="absolute inset-0">
    <img
      src={backgroundImage}
      alt="Fondo agrícola"
      class="h-full w-full object-cover opacity-30 mix-blend-overlay"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="animate-fade-up grid gap-6 divide-y divide-emerald-600/50 text-center motion-reduce:animate-none sm:gap-8 md:grid-cols-3 md:divide-x md:divide-y-0"
    >
      {
        items.map((item, index) => (
          <div class={["p-3 sm:p-4", index === 0 ? "" : "pt-7 sm:pt-8 md:pt-4"].join(" ")}>
            <div class="mb-2 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
              {item.value}
            </div>
            <div class="text-xs font-medium tracking-wide text-emerald-200 uppercase sm:text-sm">
              {item.label}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
