---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { globalPlaceholderImage } from "../../../data/media";

interface StatItem {
  value: string;
  label: string;
}

interface Props {
  items?: StatItem[];
  backgroundImage?: ImageMetadata;
}

const {
  items = [
    {
      value: "100%",
      label: "Calidad genetica",
    },
    {
      value: "Sanos",
      label: "Cultivos libres de plagas",
    },
    {
      value: "Maximo",
      label: "Rendimiento productivo",
    },
  ],
  backgroundImage = globalPlaceholderImage,
} = Astro.props;
---

<section
  class="relative overflow-hidden bg-linear-to-r from-emerald-800 to-teal-900 py-16"
>
  <div class="absolute inset-0">
    <Image
      src={backgroundImage}
      alt="Fondo agricultura"
      class="h-full w-full object-cover opacity-30 mix-blend-overlay"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="animate-fade-up grid gap-8 divide-y divide-emerald-600/50 text-center motion-reduce:animate-none md:grid-cols-3 md:divide-x md:divide-y-0"
    >
      {
        items.map((item, index) => (
          <div class={["p-4", index === 0 ? "" : "pt-8 md:pt-4"].join(" ")}>
            <div class="mb-2 text-5xl font-extrabold tracking-tight text-white">
              {item.value}
            </div>
            <div class="text-sm font-medium tracking-wide text-emerald-200 uppercase">
              {item.label}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
