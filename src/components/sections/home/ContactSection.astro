---
import Button from "@ui/Button.astro";
import InfoItem from "@ui/InfoItem.astro";
import type { IconName } from "../../../data/icons";
import { globalPlaceholderImage } from "../../../data/media";

interface ContactDetail {
  icon: IconName;
  label: string;
  value: string;
  tone?: "emerald" | "teal";
}

interface Props {
  id?: string;
  title?: string;
  emphasizedText?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  contactDetails?: ContactDetail[];
  options?: string[];
}

const {
  id = "contacto",
  title = "Agenda una asesoría para tu",
  emphasizedText = "próximo ciclo productivo",
  description = "Cuéntanos tu objetivo de cultivo y te ayudamos a definir el servicio técnico más conveniente según etapa, recursos y condiciones de campo.",
  image = globalPlaceholderImage,
  imageAlt = "Cultivo saludable en campo agrícola",
  contactDetails = [
    {
      icon: "map-pin",
      label: "Ubicación",
      value: "Tabasco, México",
    },
    {
      icon: "mail",
      label: "Correo electrónico",
      value: "contacto@agrochoco.com.mx",
    },
    {
      icon: "phone",
      label: "Atención / WhatsApp",
      value: "+52 123 456 7890",
    },
  ],
  options = [
    "Micropropagación in vitro",
    "Clonación de plantas",
    "Análisis de suelos",
    "Asesoría técnica agrícola",
  ],
} = Astro.props;
---

<section
  id={id}
  class="relative overflow-hidden bg-linear-to-b from-white via-emerald-50/70 to-emerald-100/80 py-16 sm:py-20 lg:py-24"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 hidden -translate-y-1/2 sm:block"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative h-14">
        <div
          class="absolute inset-x-0 top-1/2 h-px bg-linear-to-r from-transparent via-emerald-300/80 to-transparent"
        >
        </div>
        <div
          class="absolute top-1/2 left-1/2 h-5 w-5 -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-sm border border-emerald-300/80 bg-white/90 shadow-sm"
        >
        </div>
        <div
          class="absolute top-1/2 left-[calc(50%-2.5rem)] h-2 w-2 -translate-y-1/2 rounded-full bg-emerald-300/80"
        >
        </div>
        <div
          class="absolute top-1/2 left-[calc(50%+2rem)] h-2 w-2 -translate-y-1/2 rounded-full bg-emerald-300/80"
        >
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative z-10 grid items-center gap-10 sm:gap-12 lg:grid-cols-2">
      <div class="animate-fade-up motion-reduce:animate-none">
        <h2
          class="mb-5 text-xl leading-tight font-extrabold text-gray-900 sm:mb-6 sm:text-3xl md:text-4xl"
        >
          {title}
          <span class="text-emerald-600">{emphasizedText}</span>
        </h2>
        <p
          class="mb-6 text-base leading-relaxed text-gray-600 sm:mb-8 sm:text-lg"
        >
          {description}
        </p>

        <div class="group relative mb-8">
          <div
            class="absolute -inset-2 rounded-[1.75rem] bg-linear-to-r from-emerald-300/30 via-teal-200/25 to-emerald-200/30 blur-xl"
          >
          </div>
          <div
            class="relative overflow-hidden rounded-3xl border border-white/70 shadow-xl"
          >
            <img
              src={image}
              loading="lazy"
              decoding="async"
              alt={imageAlt}
              class="h-56 w-full object-cover transition-transform duration-700 group-hover:scale-105 sm:h-64"
            />
            <div
              class="absolute inset-0 bg-linear-to-t from-emerald-900/45 via-transparent to-transparent"
            >
            </div>
            <div
              class="absolute bottom-4 left-4 rounded-full border border-white/40 bg-white/90 px-4 py-2 text-xs font-semibold tracking-wide text-emerald-800 shadow-sm"
            >
              Soluciones de campo y laboratorio
            </div>
          </div>
        </div>

        <div class="space-y-6">
          {
            contactDetails.map((item) => (
              <InfoItem
                icon={item.icon}
                label={item.label}
                value={item.value}
                tone={item.tone}
              />
            ))
          }
        </div>
      </div>

      <div
        class="animate-fade-up [animation-delay:200ms] motion-reduce:animate-none"
      >
        <form
          class="rounded-2xl border border-emerald-100 bg-white/75 p-5 shadow-lg backdrop-blur-xs sm:p-8"
        >
          <h3 class="mb-6 text-xl font-bold text-gray-900 sm:text-2xl">
            Solicitar Asesoría
          </h3>
          <div class="space-y-4">
            <div>
              <label class="mb-1 block text-sm font-medium text-gray-700"
                >Nombre o Empresa</label
              >
              <input
                type="text"
                class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 transition-all outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500"
                placeholder="Ej. Agrícola del Sur"
              />
            </div>
            <div>
              <label class="mb-1 block text-sm font-medium text-gray-700"
                >Servicio de interés</label
              >
              <select
                class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 transition-all outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500"
              >
                {options.map((option) => <option>{option}</option>)}
              </select>
            </div>
            <div>
              <label class="mb-1 block text-sm font-medium text-gray-700"
                >Mensaje</label
              >
              <textarea
                rows="4"
                class="w-full resize-none rounded-lg border border-gray-300 bg-white px-4 py-3 transition-all outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500"
                placeholder="Cuéntanos sobre tu cultivo, ubicación y objetivo..."
              ></textarea>
            </div>
            <Button type="submit" fullWidth className="rounded-lg py-3.5">
              Enviar solicitud
            </Button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
