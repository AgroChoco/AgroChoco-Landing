---
import { Picture } from "astro:assets";
import Button from "@ui/Button.astro";
import InfoItem from "@ui/InfoItem.astro";
import type { IconName } from "../../../data/icons";
import { globalPlaceholderImage } from "../../../data/media";
import type { ImageMetadata } from "astro";

interface ContactDetail {
    icon: IconName;
    label: string;
    value: string;
    tone?: "emerald" | "teal";
}

interface Props {
    id?: string;
    title?: string;
    emphasizedText?: string;
    description?: string;
    image?: ImageMetadata;
    imageAlt?: string;
    contactDetails?: ContactDetail[];
    options?: string[];
}

const {
    id = "contacto",
    title = "Lleva tu produccion al",
    emphasizedText = "siguiente nivel",
    description = "Ya seas un pequeno agricultor, un gran invernadero o una empresa agroindustrial, tenemos el paquete tecnologico adecuado para ti.",
    image = globalPlaceholderImage,
    imageAlt = "Cultivo saludable en campo agricola",
    contactDetails = [
        {
            icon: "map-pin",
            label: "Ubicacion",
            value: "Tabasco, Mexico",
        },
        {
            icon: "mail",
            label: "Correo Electronico",
            value: "contacto@agrochoco.com.mx",
        },
        {
            icon: "phone",
            label: "Atencion / WhatsApp",
            value: "+52 123 456 7890",
        },
    ],
    options = [
        "Plantas Elite (Cacao / Banano)",
        "Micropropagacion / Clonacion",
        "Analisis de suelo",
        "Asesoria y Manejo",
    ],
} = Astro.props;
---

<section
    id={id}
    class="relative overflow-hidden py-16 sm:py-20 lg:py-24 bg-linear-to-b from-white via-emerald-50/70 to-emerald-100/80"
>
    <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 top-0 -translate-y-1/2"
    >
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="relative h-14">
                <div
                    class="absolute inset-x-0 top-1/2 h-px bg-linear-to-r from-transparent via-emerald-300/80 to-transparent"
                >
                </div>
                <div
                    class="absolute left-1/2 top-1/2 h-5 w-5 -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-sm border border-emerald-300/80 bg-white/90 shadow-sm"
                >
                </div>
                <div
                    class="absolute left-[calc(50%-2.5rem)] top-1/2 h-2 w-2 -translate-y-1/2 rounded-full bg-emerald-300/80"
                >
                </div>
                <div
                    class="absolute left-[calc(50%+2rem)] top-1/2 h-2 w-2 -translate-y-1/2 rounded-full bg-emerald-300/80"
                >
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center relative z-10">
            <div class="animate-fade-up motion-reduce:animate-none">
                <h2
                    class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-gray-900 mb-5 sm:mb-6 leading-tight"
                >
                    {title}
                    <span class="text-emerald-600">{emphasizedText}</span>
                </h2>
                <p
                    class="text-base sm:text-lg text-gray-600 mb-6 sm:mb-8 leading-relaxed"
                >
                    {description}
                </p>

                <div class="relative mb-8 group">
                    <div
                        class="absolute -inset-2 rounded-[1.75rem] bg-linear-to-r from-emerald-300/30 via-teal-200/25 to-emerald-200/30 blur-xl"
                    >
                    </div>
                    <div
                        class="relative overflow-hidden rounded-3xl border border-white/70 shadow-xl"
                    >
                        <Picture
                            src={image}
                            formats={["avif", "webp"]}
                            loading="lazy"
                            decoding="async"
                            alt={imageAlt}
                            class="h-64 w-full object-cover transition-transform duration-700 group-hover:scale-105"
                        />
                        <div
                            class="absolute inset-0 bg-linear-to-t from-emerald-900/45 via-transparent to-transparent"
                        >
                        </div>
                        <div
                            class="absolute bottom-4 left-4 rounded-full border border-white/40 bg-white/90 px-4 py-2 text-xs font-semibold tracking-wide text-emerald-800 shadow-sm"
                        >
                            Soluciones de campo y laboratorio
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    {
                        contactDetails.map((item) => (
                            <InfoItem
                                icon={item.icon}
                                label={item.label}
                                value={item.value}
                                tone={item.tone}
                            />
                        ))
                    }
                </div>
            </div>

            <div
                class="animate-fade-up [animation-delay:200ms] motion-reduce:animate-none"
            >
                <form
                    class="bg-white/75 backdrop-blur-xs p-5 sm:p-8 rounded-2xl border border-emerald-100 shadow-lg"
                >
                    <h3 class="text-2xl font-bold text-gray-900 mb-6">
                        Solicitar Cotizacion
                    </h3>
                    <div class="space-y-4">
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-700 mb-1"
                                >Nombre o Empresa</label
                            >
                            <input
                                type="text"
                                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all bg-white"
                                placeholder="Ej. Agricola del Sur"
                            />
                        </div>
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-700 mb-1"
                                >Servicio o Producto de interes</label
                            >
                            <select
                                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all bg-white"
                            >
                                {
                                    options.map((option) => (
                                        <option>{option}</option>
                                    ))
                                }
                            </select>
                        </div>
                        <div>
                            <label
                                class="block text-sm font-medium text-gray-700 mb-1"
                                >Mensaje</label
                            >
                            <textarea
                                rows="4"
                                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition-all resize-none bg-white"
                                placeholder="Cuentanos sobre tu cultivo..."
                            ></textarea>
                        </div>
                        <Button
                            type="submit"
                            fullWidth
                            className="rounded-lg py-3.5"
                        >
                            Enviar Mensaje
                        </Button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
