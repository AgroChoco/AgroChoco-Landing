---
import { Image } from "astro:assets";
import SectionHeading from "@ui/SectionHeading.astro";
import Icon from "@ui/Icon.astro";
import type { ImageMetadata } from "astro";
import type { IconName } from "@data/icons";
import { servicesLandingBackgroundImage } from "../../../data/media";

interface ServiceItem {
  icon: IconName;
  title: string;
  image: ImageMetadata;
  description: string;
  href?: string;
}

interface Props {
  id?: string;
  services: ServiceItem[];
  eyebrow?: string;
  title?: string;
  description?: string;
  showAll?: boolean;
}

const {
  id = "servicios",
  services,
  eyebrow = "Servicios especializados",
  title = "Servicios",
  description = "Conoce nuestros servicios de micropropagación, clonación, análisis de suelos y asesoría técnica para aumentar rendimiento, reducir riesgos y tomar decisiones con respaldo profesional.",
  showAll = false,
} = Astro.props;

const delays = ["", "[animation-delay:100ms]", "[animation-delay:200ms]"];
const visibleServices = showAll ? services : services.slice(0, 4);
const spanClasses = [
  "md:col-span-4 lg:col-span-8",
  "md:col-span-2 lg:col-span-4",
  "md:col-span-3 lg:col-span-6",
  "md:col-span-3 lg:col-span-6",
];
---

<section id={id} class="relative overflow-hidden bg-white py-20 sm:py-24">
  <div class="pointer-events-none absolute inset-0 z-0 flex flex-col">
    <div class="h-2/5 w-full sm:h-3/5 md:h-1/3">
      <img
        src={servicesLandingBackgroundImage}
        alt="Fondo de servicios"
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover"
      />
      <div
        class="absolute inset-x-0 top-0 h-2/5 bg-linear-to-r from-emerald-800 to-teal-900 opacity-75 sm:h-3/5 md:h-1/3"
      >
      </div>
    </div>
    <div class="h-3/5 w-full bg-white sm:h-2/5 md:h-2/3"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow={eyebrow}
      title={title}
      description={description}
      tone="hero"
    />

    <div class="md:hidden" data-services-mobile-carousel>
      <div class="relative px-1">
        <div class="overflow-hidden rounded-2xl">
          <div
            class="flex transition-transform duration-500 ease-out"
            data-services-carousel-track
          >
            {
              visibleServices.map((service) => (
                <div class="w-full shrink-0 px-0">
                  <a
                    href={service.href ?? "#"}
                    aria-label={`Ver servicio ${service.title}`}
                    class="group block h-full rounded-2xl focus-visible:ring-2 focus-visible:ring-emerald-500/70 focus-visible:ring-offset-4 focus-visible:outline-none"
                  >
                    <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm">
                      <div class="relative h-36 overflow-hidden">
                        <Image
                          src={service.image}
                          alt={service.title}
                          loading="lazy"
                          decoding="async"
                          class="h-full w-full object-cover opacity-90 transition-transform duration-500 group-hover:scale-105 group-hover:opacity-100"
                        />
                        <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent" />
                        <div class="absolute bottom-3 left-4 rounded-lg bg-white/20 p-2 backdrop-blur-md">
                          <Icon
                            name={service.icon}
                            className="w-6 h-6 text-white"
                          />
                        </div>
                      </div>

                      <div class="flex grow flex-col p-5">
                        <h4 class="mb-2 text-lg font-bold text-gray-900 transition-colors group-hover:text-emerald-700">
                          {service.title}
                        </h4>
                        <p class="[display:-webkit-box] grow overflow-hidden text-sm leading-relaxed text-gray-600 [-webkit-box-orient:vertical] [-webkit-line-clamp:4]">
                          {service.description}
                        </p>
                        <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 transition-colors group-hover:text-emerald-800">
                          Ver servicio
                          <Icon
                            name="arrow-up-right"
                            className="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                          />
                        </span>
                      </div>
                    </article>
                  </a>
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="pointer-events-none absolute inset-y-0 right-1 left-1 flex items-center justify-between"
        >
          <button
            type="button"
            class="pointer-events-auto flex h-10 w-10 items-center justify-center rounded-full border border-emerald-100 bg-white/95 text-emerald-800 shadow-md transition-transform active:scale-95"
            aria-label="Servicio anterior"
            data-services-carousel-prev
          >
            <Icon name="chevron-right" className="h-5 w-5 rotate-180" />
          </button>
          <button
            type="button"
            class="pointer-events-auto flex h-10 w-10 items-center justify-center rounded-full border border-emerald-100 bg-white/95 text-emerald-800 shadow-md transition-transform active:scale-95"
            aria-label="Siguiente servicio"
            data-services-carousel-next
          >
            <Icon name="chevron-right" className="h-5 w-5" />
          </button>
        </div>
      </div>

      <div
        class="mt-5 flex items-center justify-center gap-2"
        aria-label="Indicador de servicio"
        data-services-carousel-dots
      >
        {
          visibleServices.map((_, dotIndex) => (
            <button
              type="button"
              class={[
                "h-2 rounded-full transition-all duration-300",
                dotIndex === 0 ? "w-8 bg-emerald-600" : "w-2 bg-emerald-300/70",
              ].join(" ")}
              aria-label={`Ir al servicio ${dotIndex + 1}`}
              aria-current={dotIndex === 0 ? "true" : "false"}
              data-services-carousel-dot
              data-dot-index={dotIndex}
            />
          ))
        }
      </div>
    </div>

    <div class="hidden gap-6 md:grid md:grid-cols-6 md:gap-8 lg:grid-cols-12">
      {
        visibleServices.map((service, index) => (
          <div
            class={[
              "animate-fade-up motion-reduce:animate-none",
              delays[index % delays.length],
              spanClasses[index % spanClasses.length],
            ].join(" ")}
          >
            <a
              href={service.href ?? "#"}
              aria-label={`Ver servicio ${service.title}`}
              class="group block h-full rounded-2xl focus-visible:ring-2 focus-visible:ring-emerald-500/70 focus-visible:ring-offset-4 focus-visible:outline-none"
            >
              <article class="group flex h-full transform flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition-all duration-300 hover:-translate-y-2 hover:shadow-xl">
                <div class="relative h-40 overflow-hidden">
                  <Image
                    src={service.image}
                    alt={service.title}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover opacity-90 transition-transform duration-500 group-hover:scale-105 group-hover:opacity-100"
                  />
                  <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent" />
                  <div class="absolute bottom-4 left-6 rounded-lg bg-white/20 p-2 backdrop-blur-md">
                    <Icon name={service.icon} className="w-8 h-8 text-white" />
                  </div>
                </div>

                <div class="flex grow flex-col p-6">
                  <h4 class="mb-3 text-xl font-bold text-gray-900 transition-colors group-hover:text-emerald-700">
                    {service.title}
                  </h4>
                  <p class="grow text-sm leading-relaxed text-gray-600">
                    {service.description}
                  </p>
                  <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 transition-colors group-hover:text-emerald-800">
                    Ver servicio
                    <Icon
                      name="arrow-up-right"
                      className="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                    />
                  </span>
                </div>
              </article>
            </a>
          </div>
        ))
      }
    </div>
  </div>

  <script is:inline>
    (() => {
      const carousel = document.querySelector(
        "[data-services-mobile-carousel]",
      );
      if (!carousel) return;

      const track = carousel.querySelector("[data-services-carousel-track]");
      const prevBtn = carousel.querySelector("[data-services-carousel-prev]");
      const nextBtn = carousel.querySelector("[data-services-carousel-next]");
      const dots = carousel.querySelectorAll("[data-services-carousel-dot]");
      const slides = track?.children ? Array.from(track.children) : [];

      if (
        !track ||
        slides.length === 0 ||
        !prevBtn ||
        !nextBtn ||
        dots.length === 0
      ) {
        return;
      }

      let index = 0;
      let touchStartX = 0;
      let touchEndX = 0;

      const render = () => {
        track.style.transform = `translateX(-${index * 100}%)`;

        dots.forEach((dot, dotIndex) => {
          const isActive = dotIndex === index;
          dot.classList.toggle("w-8", isActive);
          dot.classList.toggle("bg-emerald-600", isActive);
          dot.classList.toggle("w-2", !isActive);
          dot.classList.toggle("bg-emerald-300/70", !isActive);
          dot.setAttribute("aria-current", isActive ? "true" : "false");
        });
      };

      const prev = () => {
        index = index === 0 ? slides.length - 1 : index - 1;
        render();
      };

      const next = () => {
        index = index === slides.length - 1 ? 0 : index + 1;
        render();
      };

      prevBtn.addEventListener("click", prev);
      nextBtn.addEventListener("click", next);

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const dotIndex = Number(dot.getAttribute("data-dot-index"));
          if (Number.isNaN(dotIndex)) return;
          index = dotIndex;
          render();
        });
      });

      carousel.addEventListener("touchstart", (event) => {
        touchStartX = event.changedTouches[0]?.clientX ?? 0;
      });

      carousel.addEventListener("touchend", (event) => {
        touchEndX = event.changedTouches[0]?.clientX ?? 0;
        const distance = touchEndX - touchStartX;

        if (Math.abs(distance) < 40) return;
        if (distance < 0) {
          next();
        } else {
          prev();
        }
      });

      render();
    })();
  </script>
</section>
