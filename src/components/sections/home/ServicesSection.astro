---
import { Image } from "astro:assets";
import SectionHeading from "@ui/SectionHeading.astro";
import Icon from "@ui/Icon.astro";
import type { ServiceItem } from "../../../data/services";

interface Props {
    id?: string;
    services: ServiceItem[];
    eyebrow?: string;
    title?: string;
    description?: string;
}

const {
    id = "servicios",
    services,
    eyebrow = "Procesos que seguimos",
    title = "Nuestro Proceso Tecnico Agricola",
    description = "Iniciamos con diagnostico, continuamos con plan tecnico y ejecutamos seguimiento constante para asegurar resultados en cada etapa del cultivo.",
} = Astro.props;

const delays = ["", "[animation-delay:100ms]", "[animation-delay:200ms]"];
const visibleServices = services.slice(0, 4);
const spanClasses = [
    "md:col-span-4 lg:col-span-8",
    "md:col-span-2 lg:col-span-4",
    "md:col-span-3 lg:col-span-6",
    "md:col-span-3 lg:col-span-6",
];
---

<section id={id} class="py-24 bg-gray-50 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionHeading
            eyebrow={eyebrow}
            title={title}
            description={description}
        />

        <div class="md:hidden" data-services-mobile-carousel>
            <div class="relative">
                <div class="overflow-hidden rounded-2xl">
                    <div
                        class="flex transition-transform duration-500 ease-out"
                        data-services-carousel-track
                    >
                        {
                            visibleServices.map((service) => (
                                <div class="w-full shrink-0 px-1">
                                    <a
                                        href={service.href ?? "#"}
                                        aria-label={`Ver articulo sobre ${service.title}`}
                                        class="group block h-full rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/70 focus-visible:ring-offset-4"
                                    >
                                        <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden h-full flex flex-col group">
                                            <div class="h-36 overflow-hidden relative">
                                                <Image
                                                    src={service.image}
                                                    alt={service.title}
                                                    loading="lazy"
                                                    decoding="async"
                                                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-90 group-hover:opacity-100"
                                                />
                                                <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent" />
                                                <div class="absolute bottom-3 left-4 bg-white/20 backdrop-blur-md p-2 rounded-lg">
                                                    <Icon
                                                        name={service.icon}
                                                        className="w-6 h-6 text-white"
                                                    />
                                                </div>
                                            </div>

                                            <div class="p-5 flex flex-col grow">
                                                <h4 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-emerald-700 transition-colors">
                                                    {service.title}
                                                </h4>
                                                <p class="text-gray-600 leading-relaxed text-sm grow overflow-hidden [display:-webkit-box] [-webkit-line-clamp:4] [-webkit-box-orient:vertical]">
                                                    {service.description}
                                                </p>
                                                <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 transition-colors group-hover:text-emerald-800">
                                                    Leer articulo
                                                    <Icon
                                                        name="arrow-up-right"
                                                        className="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                                                    />
                                                </span>
                                            </div>
                                        </article>
                                    </a>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div
                    class="pointer-events-none absolute inset-y-0 -left-2 -right-2 flex items-center justify-between"
                >
                    <button
                        type="button"
                        class="pointer-events-auto h-9 w-9 rounded-full bg-white/95 text-emerald-800 shadow-md border border-emerald-100 flex items-center justify-center active:scale-95 transition-transform"
                        aria-label="Servicio anterior"
                        data-services-carousel-prev
                    >
                        <Icon
                            name="chevron-right"
                            className="w-5 h-5 rotate-180"
                        />
                    </button>
                    <button
                        type="button"
                        class="pointer-events-auto h-9 w-9 rounded-full bg-white/95 text-emerald-800 shadow-md border border-emerald-100 flex items-center justify-center active:scale-95 transition-transform"
                        aria-label="Siguiente servicio"
                        data-services-carousel-next
                    >
                        <Icon name="chevron-right" className="w-5 h-5" />
                    </button>
                </div>
            </div>

            <div
                class="mt-5 flex items-center justify-center gap-2"
                aria-label="Indicador de servicio"
                data-services-carousel-dots
            >
                {
                    visibleServices.map((_, dotIndex) => (
                        <button
                            type="button"
                            class={[
                                "h-2 rounded-full transition-all duration-300",
                                dotIndex === 0
                                    ? "w-8 bg-emerald-600"
                                    : "w-2 bg-emerald-300/70",
                            ].join(" ")}
                            aria-label={`Ir al servicio ${dotIndex + 1}`}
                            aria-current={dotIndex === 0 ? "true" : "false"}
                            data-services-carousel-dot
                            data-dot-index={dotIndex}
                        />
                    ))
                }
            </div>
        </div>

        <div class="hidden md:grid md:grid-cols-6 lg:grid-cols-12 gap-8">
            {
                visibleServices.map((service, index) => (
                    <div
                        class={[
                            "animate-fade-up motion-reduce:animate-none",
                            delays[index % delays.length],
                            spanClasses[index % spanClasses.length],
                        ].join(" ")}
                    >
                        <a
                            href={service.href ?? "#"}
                            aria-label={`Ver articulo sobre ${service.title}`}
                            class="group block h-full rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/70 focus-visible:ring-offset-4"
                        >
                            <article class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 border border-gray-100 overflow-hidden h-full flex flex-col group">
                                <div class="h-40 overflow-hidden relative">
                                    <Image
                                        src={service.image}
                                        alt={service.title}
                                        loading="lazy"
                                        decoding="async"
                                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 opacity-90 group-hover:opacity-100"
                                    />
                                    <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent" />
                                    <div class="absolute bottom-4 left-6 bg-white/20 backdrop-blur-md p-2 rounded-lg">
                                        <Icon
                                            name={service.icon}
                                            className="w-8 h-8 text-white"
                                        />
                                    </div>
                                </div>

                                <div class="p-6 flex flex-col grow">
                                    <h4 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-emerald-700 transition-colors">
                                        {service.title}
                                    </h4>
                                    <p class="text-gray-600 leading-relaxed text-sm grow">
                                        {service.description}
                                    </p>
                                    <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 transition-colors group-hover:text-emerald-800">
                                        Leer articulo
                                        <Icon
                                            name="arrow-up-right"
                                            className="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                                        />
                                    </span>
                                </div>
                            </article>
                        </a>
                    </div>
                ))
            }
        </div>
    </div>

    <script is:inline>
        (() => {
            const carousel = document.querySelector(
                "[data-services-mobile-carousel]",
            );
            if (!carousel) return;

            const track = carousel.querySelector(
                "[data-services-carousel-track]",
            );
            const prevBtn = carousel.querySelector(
                "[data-services-carousel-prev]",
            );
            const nextBtn = carousel.querySelector(
                "[data-services-carousel-next]",
            );
            const dots = carousel.querySelectorAll(
                "[data-services-carousel-dot]",
            );
            const slides = track?.children ? Array.from(track.children) : [];

            if (
                !track ||
                slides.length === 0 ||
                !prevBtn ||
                !nextBtn ||
                dots.length === 0
            ) {
                return;
            }

            let index = 0;
            let touchStartX = 0;
            let touchEndX = 0;

            const render = () => {
                track.style.transform = `translateX(-${index * 100}%)`;

                dots.forEach((dot, dotIndex) => {
                    const isActive = dotIndex === index;
                    dot.classList.toggle("w-8", isActive);
                    dot.classList.toggle("bg-emerald-600", isActive);
                    dot.classList.toggle("w-2", !isActive);
                    dot.classList.toggle("bg-emerald-300/70", !isActive);
                    dot.setAttribute(
                        "aria-current",
                        isActive ? "true" : "false",
                    );
                });
            };

            const prev = () => {
                index = index === 0 ? slides.length - 1 : index - 1;
                render();
            };

            const next = () => {
                index = index === slides.length - 1 ? 0 : index + 1;
                render();
            };

            prevBtn.addEventListener("click", prev);
            nextBtn.addEventListener("click", next);

            dots.forEach((dot) => {
                dot.addEventListener("click", () => {
                    const dotIndex = Number(dot.getAttribute("data-dot-index"));
                    if (Number.isNaN(dotIndex)) return;
                    index = dotIndex;
                    render();
                });
            });

            carousel.addEventListener("touchstart", (event) => {
                touchStartX = event.changedTouches[0]?.clientX ?? 0;
            });

            carousel.addEventListener("touchend", (event) => {
                touchEndX = event.changedTouches[0]?.clientX ?? 0;
                const distance = touchEndX - touchStartX;

                if (Math.abs(distance) < 40) return;
                if (distance < 0) {
                    next();
                } else {
                    prev();
                }
            });

            render();
        })();
    </script>
</section>
