---
import { Picture } from "astro:assets";
import Button from "@ui/Button.astro";
import Icon from "@ui/Icon.astro";
import heroBackground from "@images/ui/placeholder.png";
import type { ImageMetadata } from "astro";

interface HighlightItem {
  icon: string;
  title: string;
  subtitle: string;
  tone?: "emerald" | "teal";
}

interface CtaLink {
  label: string;
  href: string;
  variant?: "primary" | "outline-light";
}

interface Props {
  id?: string;
  headline?: string;
  highlightedText?: string;
  description?: string;
  backgroundImage?: ImageMetadata;
  strapline?: string;
  primaryCta?: CtaLink;
  secondaryCta?: CtaLink;
  highlights?: HighlightItem[];
  layout?: "split" | "stacked";
}

const {
  id = "inicio",
  headline = "Biotecnologia Vegetal para el",
  highlightedText = "Futuro del Campo",
  description = "Impulsamos tu productividad agricola mediante la clonacion de plantas elite, analisis cientifico del suelo y asesoria tecnica especializada.",
  primaryCta = {
    label: "Ver Productos",
    href: "#productos",
    variant: "primary",
  },
  secondaryCta = {
    label: "Solicitar Asesoria",
    href: "#contacto",
    variant: "outline-light",
  },
  backgroundImage = heroBackground,
} = Astro.props;
---

<section
  id={id}
  class="relative overflow-hidden pt-16 pb-20 [clip-path:polygon(0_0,100%_0,100%_95%,0_100%)] sm:pt-20 sm:pb-28 lg:pt-32 lg:pb-48"
>
  <div class="absolute inset-0">
    <Picture
      src={backgroundImage}
      formats={["avif", "webp"]}
      alt="Campo agricola con cultivos"
      class="h-full w-full object-cover"
      loading="lazy"
      decoding="async"
    />
    <div
      class="absolute inset-0 bg-[radial-gradient(120%_90%_at_50%_0%,rgba(52,211,153,0.2)_0%,rgba(6,78,59,0)_58%)]"
    >
    </div>
    <div
      class="absolute inset-0 bg-linear-to-b from-emerald-950/90 via-emerald-900/70 to-emerald-200/20"
    >
    </div>
  </div>

  <div
    class="relative z-10 mx-auto mt-12 flex max-w-7xl items-center gap-8 px-4 sm:mt-16 sm:gap-12 sm:px-6 lg:flex-row lg:px-8"
  >
    <div
      class="animate-fade-up mx-auto w-full max-w-4xl text-center motion-reduce:animate-none"
    >
      <h1
        class="font-display mb-5 text-3xl leading-tight font-extrabold text-white sm:mb-6 sm:text-4xl md:text-5xl lg:text-6xl"
      >
        {headline}
        <span
          class="bg-linear-to-r from-emerald-300 to-teal-200 bg-clip-text text-transparent"
        >
          {" "}{highlightedText}
        </span>
      </h1>

      <p
        class="mx-auto mb-8 text-base leading-relaxed text-emerald-50 sm:mb-10 sm:text-lg md:text-xl"
      >
        {description}
      </p>

      <div class="flex flex-col justify-center gap-3 sm:flex-row sm:gap-4">
        <Button
          href={primaryCta.href}
          variant={primaryCta.variant}
          size="lg"
          className="group text-base shadow-lg hover:shadow-emerald-500/30 sm:text-lg"
        >
          {primaryCta.label}
          <Icon
            name="chevron-right"
            className="h-5 w-5 transition-transform group-hover:translate-x-1"
          />
        </Button>
        <Button
          href={secondaryCta.href}
          variant={secondaryCta.variant}
          size="lg"
          className="text-base backdrop-blur-sm sm:text-lg"
        >
          {secondaryCta.label}
        </Button>
      </div>
    </div>
  </div>
</section>
