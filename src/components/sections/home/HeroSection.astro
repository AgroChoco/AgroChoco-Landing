---
import { Picture } from "astro:assets";
import Button from "@ui/Button.astro";
import Icon from "@ui/Icon.astro";
import heroBackground from "@images/ui/placeholder.png";
import type { ImageMetadata } from "astro";

interface HighlightItem {
    icon: string;
    title: string;
    subtitle: string;
    tone?: "emerald" | "teal";
}

interface CtaLink {
    label: string;
    href: string;
    variant?: "primary" | "outline-light";
}

interface Props {
    id?: string;
    headline?: string;
    highlightedText?: string;
    description?: string;
    backgroundImage?: ImageMetadata;
    strapline?: string;
    primaryCta?: CtaLink;
    secondaryCta?: CtaLink;
    highlights?: HighlightItem[];
    layout?: "split" | "stacked";
}

const {
    id = "inicio",
    headline = "Biotecnologia Vegetal para el",
    highlightedText = "Futuro del Campo",
    description = "Impulsamos tu productividad agricola mediante la clonacion de plantas elite, analisis cientifico del suelo y asesoria tecnica especializada.",
    primaryCta = {
        label: "Ver Productos",
        href: "#productos",
        variant: "primary",
    },
    secondaryCta = {
        label: "Solicitar Asesoria",
        href: "#contacto",
        variant: "outline-light",
    },
    backgroundImage = heroBackground,
} = Astro.props;
---

<section
    id={id}
    class="relative pt-16 pb-20 sm:pt-20 sm:pb-28 lg:pt-32 lg:pb-48 overflow-hidden [clip-path:polygon(0_0,100%_0,100%_95%,0_100%)]"
>
    <div class="absolute inset-0">
        <Picture
            src={backgroundImage}
            formats={["avif", "webp"]}
            alt="Campo agricola con cultivos"
            class="h-full w-full object-cover"
            loading="lazy"
            decoding="async"
        />
        <div
            class="absolute inset-0 bg-[radial-gradient(120%_90%_at_50%_0%,rgba(52,211,153,0.2)_0%,rgba(6,78,59,0)_58%)]"
        >
        </div>
        <div
            class="absolute inset-0 bg-linear-to-b from-emerald-950/90 via-emerald-900/70 to-emerald-200/20"
        >
        </div>
    </div>

    <div
        class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 sm:mt-16 flex lg:flex-row items-center gap-8 sm:gap-12"
    >
        <div
            class="w-full max-w-4xl mx-auto text-center animate-fade-up motion-reduce:animate-none"
        >
            <h1
                class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-5 sm:mb-6"
            >
                {headline}
                <span
                    class="text-transparent bg-clip-text bg-linear-to-r from-emerald-300 to-teal-200"
                >
                    {" "}{highlightedText}
                </span>
            </h1>

            <p
                class="text-base sm:text-lg md:text-xl text-emerald-50 mb-8 sm:mb-10 leading-relaxed mx-auto"
            >
                {description}
            </p>

            <div
                class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center"
            >
                <Button
                    href={primaryCta.href}
                    variant={primaryCta.variant}
                    size="lg"
                    className="group text-base sm:text-lg shadow-lg hover:shadow-emerald-500/30"
                >
                    {primaryCta.label}
                    <Icon
                        name="chevron-right"
                        className="w-5 h-5 group-hover:translate-x-1 transition-transform"
                    />
                </Button>
                <Button
                    href={secondaryCta.href}
                    variant={secondaryCta.variant}
                    size="lg"
                    className="text-base sm:text-lg backdrop-blur-sm"
                >
                    {secondaryCta.label}
                </Button>
            </div>
        </div>
    </div>
</section>
