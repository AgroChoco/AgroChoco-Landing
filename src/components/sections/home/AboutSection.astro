---
import { Picture } from "astro:assets";
import SectionHeading from "@ui/SectionHeading.astro";
import SurfaceCard from "@ui/SurfaceCard.astro";
import Icon from "@ui/Icon.astro";
import { globalPlaceholderImage } from "../../../data/media";
import type { ImageMetadata } from "astro";

interface Pillar {
  order: string;
  title: string;
  description: string;
  tone?: "emerald" | "teal";
  href?: string;
}

interface Props {
  id?: string;
  image?: ImageMetadata;
  location?: string;
  pillars?: Pillar[];
}

const {
  id = "nosotros",
  image = globalPlaceholderImage,
  location = "Tabasco, Mexico",
  pillars = [
    {
      order: "01",
      title: "Mision",
      description:
        "Impulsar la productividad agricola mediante tecnologia biotecnologica, analisis de suelo y asesoria tecnica especializada para maximizar tu rentabilidad.",
      tone: "emerald",
      href: "/articulos/mision-vision#mision",
    },
    {
      order: "02",
      title: "Vision",
      description:
        "Ser lideres en biotecnologia agricola en el sureste de Mexico, reconocidos por la calidad de nuestras plantas y el impacto productivo.",
      tone: "teal",
      href: "/articulos/mision-vision#vision",
    },
  ],
} = Astro.props;
---

<section id={id} class="relative bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Conoce nuestra empresa"
      title="Especialistas en Biotecnologia Vegetal"
    />

    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
      <div
        class="animate-fade-up relative [animation-delay:100ms] motion-reduce:animate-none"
      >
        <div
          class="absolute -inset-4 -rotate-2 transform rounded-3xl bg-emerald-50"
        >
        </div>
        <Picture
          src={image}
          formats={["avif", "webp"]}
          loading="lazy"
          decoding="async"
          alt="Laboratorio biotecnologico"
          class="relative z-10 h-112.5 w-full rounded-2xl object-cover shadow-xl"
        />
        <div
          class="absolute -right-6 -bottom-6 z-20 hidden rounded-xl border border-gray-100 bg-white p-6 shadow-xl md:block"
        >
          <div class="flex items-center gap-4">
            <div class="rounded-full bg-emerald-100 p-3 text-emerald-600">
              <Icon name="map-pin" className="h-8 w-8" />
            </div>
            <div>
              <p class="text-lg font-bold text-gray-900">Ubicacion principal</p>
              <p class="text-gray-600">{location}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="relative flex flex-col gap-6 lg:justify-center lg:gap-7">
        {
          pillars.map((pillar, index) => (
            <div
              class={[
                "animate-fade-up",
                "relative w-full",
                index === 0
                  ? "[animation-delay:300ms]"
                  : "[animation-delay:400ms]",
                "motion-reduce:animate-none",
              ].join(" ")}
            >
              <a
                href={pillar.href ?? "#"}
                aria-label={`Leer articulo sobre ${pillar.title}`}
                class="group block rounded-xl focus-visible:ring-2 focus-visible:ring-emerald-500/60 focus-visible:ring-offset-4 focus-visible:outline-none"
              >
                <SurfaceCard
                  tone={pillar.tone === "teal" ? "teal" : "emerald"}
                  hover="lift"
                  className="p-6 md:p-7 h-full min-h-56 relative overflow-hidden cursor-pointer transition-transform duration-300 group-hover:-translate-y-0.5"
                >
                  <h4
                    class={[
                      "mb-3 flex items-center gap-2 text-xl font-bold",
                      pillar.tone === "teal"
                        ? "text-teal-800"
                        : "text-emerald-800",
                    ].join(" ")}
                  >
                    <span
                      class={[
                        "flex h-8 w-8 items-center justify-center rounded-full bg-white text-sm font-bold shadow-sm",
                        pillar.tone === "teal"
                          ? "text-teal-700"
                          : "text-emerald-700",
                      ].join(" ")}
                    >
                      {pillar.order}
                    </span>
                    {pillar.title}
                  </h4>
                  <p class="text-sm text-gray-700">{pillar.description}</p>
                  <div
                    class={[
                      "mt-4 inline-flex items-center gap-2 text-sm font-semibold transition-colors duration-300",
                      pillar.tone === "teal"
                        ? "text-teal-700 group-hover:text-teal-800"
                        : "text-emerald-700 group-hover:text-emerald-800",
                    ].join(" ")}
                  >
                    Leer articulo
                    <Icon
                      name="arrow-up-right"
                      className="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                    />
                  </div>
                </SurfaceCard>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
