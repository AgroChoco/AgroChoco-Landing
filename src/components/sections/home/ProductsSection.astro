---
import { Image, Picture } from "astro:assets";
import SectionHeading from "@ui/SectionHeading.astro";
import Icon from "@ui/Icon.astro";
import type { ProductItem } from "../../../data/products";
import { globalPlaceholderImage } from "../../../data/media";
import type { ImageMetadata } from "astro";

interface Props {
    id?: string;
    products: ProductItem[];
    eyebrow?: string;
    title?: string;
    backgroundImage?: ImageMetadata;
}

const {
    id = "productos",
    products,
    eyebrow = "Catalogo especializado",
    title = "Nuestros Productos",
    backgroundImage = globalPlaceholderImage,
} = Astro.props;

const delays = ["", "[animation-delay:100ms]", "[animation-delay:200ms]"];
const toSlug = (text: string) =>
    text
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/(^-|-$)/g, "");

const mobileCarouselId = `${id}-mobile-carousel`;
---

<section id={id} class="py-24 bg-emerald-900 relative overflow-hidden">
    <div class="absolute inset-0 z-0">
        <Image
            src={backgroundImage}
            alt="Plantacion"
            class="w-full h-full object-cover opacity-10"
            loading="lazy"
            decoding="async"
        />
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <SectionHeading eyebrow={eyebrow} title={title} tone="light" />

        <div class="md:hidden">
            <div class="relative" data-mobile-carousel-wrapper>
                <div
                    class="overflow-hidden rounded-2xl"
                    id={mobileCarouselId}
                    data-mobile-carousel
                >
                    <div
                        class="flex transition-transform duration-500 ease-out"
                        data-carousel-track
                    >
                        {
                            products.map((product) => {
                                const productHref = `/productos/${toSlug(product.name)}`;

                                return (
                                    <div class="w-full shrink-0 px-1">
                                        <a
                                            href={productHref}
                                            aria-label={`Ver pagina del producto ${product.name}`}
                                            class="group block h-full rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300 focus-visible:ring-offset-4 focus-visible:ring-offset-emerald-900"
                                        >
                                            <article class="bg-white rounded-2xl overflow-hidden shadow-xl flex flex-col h-full border border-gray-100 relative">
                                                <div class="h-56 overflow-hidden relative">
                                                    <Picture
                                                        src={product.image}
                                                        formats={[
                                                            "avif",
                                                            "webp",
                                                        ]}
                                                        loading="lazy"
                                                        decoding="async"
                                                        alt={product.name}
                                                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                                                    />
                                                    <div class="absolute inset-0 bg-linear-to-t from-emerald-900/30 via-transparent to-transparent opacity-80" />
                                                </div>

                                                <div class="p-6 flex flex-col grow">
                                                    <div class="mb-4">
                                                        <span class="inline-flex items-center rounded-full bg-emerald-100 text-emerald-800 px-2.5 py-1 text-xs font-medium">
                                                            Biotecnologia
                                                            agricola
                                                        </span>
                                                    </div>
                                                    <h4 class="text-xl font-bold text-gray-900 mb-3">
                                                        {product.name}
                                                    </h4>
                                                    <p class="text-gray-600 mb-6 grow">
                                                        {product.desc}
                                                    </p>
                                                    <div class="mt-auto flex items-center justify-between border-t border-gray-100 pt-4">
                                                        <span class="text-emerald-700 font-bold flex items-center gap-2 transition-colors group-hover:text-emerald-800">
                                                            Ver detalles
                                                            <Icon
                                                                name="arrow-up-right"
                                                                className="w-4 h-4 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                                                            />
                                                        </span>
                                                    </div>
                                                </div>
                                            </article>
                                        </a>
                                    </div>
                                );
                            })
                        }
                    </div>

                    <div
                        class="pointer-events-none absolute inset-y-0 -left-2 -right-2 flex items-center justify-between"
                    >
                        <button
                            type="button"
                            class="pointer-events-auto h-9 w-9 rounded-full bg-white/95 text-emerald-800 shadow-md border border-emerald-100 flex items-center justify-center active:scale-95 transition-transform"
                            aria-label="Producto anterior"
                            data-carousel-prev
                        >
                            <Icon
                                name="chevron-right"
                                className="w-5 h-5 rotate-180"
                            />
                        </button>
                        <button
                            type="button"
                            class="pointer-events-auto h-9 w-9 rounded-full bg-white/95 text-emerald-800 shadow-md border border-emerald-100 flex items-center justify-center active:scale-95 transition-transform"
                            aria-label="Siguiente producto"
                            data-carousel-next
                        >
                            <Icon name="chevron-right" className="w-5 h-5" />
                        </button>
                    </div>
                </div>
            </div>

            <div
                class="mt-5 flex items-center justify-center gap-2"
                aria-label="Indicador de producto"
                data-carousel-dots
            >
                {
                    products.map((_, dotIndex) => (
                        <button
                            type="button"
                            class={[
                                "h-2 rounded-full transition-all duration-300",
                                dotIndex === 0
                                    ? "w-8 bg-emerald-200"
                                    : "w-2 bg-emerald-200/45",
                            ].join(" ")}
                            aria-label={`Ir al producto ${dotIndex + 1}`}
                            aria-current={dotIndex === 0 ? "true" : "false"}
                            data-carousel-dot
                            data-dot-index={dotIndex}
                        />
                    ))
                }
            </div>
        </div>

        <div class="hidden md:grid md:grid-cols-3 md:auto-rows-fr gap-8">
            {
                products.map((product, index) => {
                    const productHref = `/productos/${toSlug(product.name)}`;

                    return (
                        <div
                            class={[
                                "animate-fade-up motion-reduce:animate-none",
                                "h-full",
                                delays[index % delays.length],
                            ].join(" ")}
                        >
                            <a
                                href={productHref}
                                aria-label={`Ver pagina del producto ${product.name}`}
                                class="group block h-full rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300 focus-visible:ring-offset-4 focus-visible:ring-offset-emerald-900"
                            >
                                <article class="bg-white rounded-2xl overflow-hidden shadow-xl transform transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl flex flex-col h-full border border-gray-100 relative">
                                    <div class="h-56 overflow-hidden relative">
                                        <Picture
                                            src={product.image}
                                            formats={["avif", "webp"]}
                                            loading="lazy"
                                            decoding="async"
                                            alt={product.name}
                                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                                        />
                                        <div class="absolute inset-0 bg-linear-to-t from-emerald-900/30 via-transparent to-transparent opacity-80" />
                                    </div>

                                    <div class="p-8 flex flex-col grow">
                                        <div class="mb-4">
                                            <span class="inline-flex items-center rounded-full bg-emerald-100 text-emerald-800 px-2.5 py-1 text-xs font-medium">
                                                Biotecnologia agricola
                                            </span>
                                        </div>
                                        <h4 class="text-xl font-bold text-gray-900 mb-3">
                                            {product.name}
                                        </h4>
                                        <p class="text-gray-600 mb-6 grow">
                                            {product.desc}
                                        </p>
                                        <div class="mt-auto flex items-center justify-between border-t border-gray-100 pt-4">
                                            <span class="text-emerald-700 font-bold flex items-center gap-2 transition-colors group-hover:text-emerald-800">
                                                Ver detalles
                                                <Icon
                                                    name="arrow-up-right"
                                                    className="w-4 h-4 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                                                />
                                            </span>
                                        </div>
                                    </div>
                                </article>
                            </a>
                        </div>
                    );
                })
            }
        </div>
    </div>

    <script is:inline>
        (() => {
            const carousel = document.querySelector("[data-mobile-carousel]");
            if (!carousel) return;

            const track = carousel.querySelector("[data-carousel-track]");
            const prevBtn = carousel.parentElement?.querySelector(
                "[data-carousel-prev]",
            );
            const nextBtn = carousel.parentElement?.querySelector(
                "[data-carousel-next]",
            );
            const dots =
                carousel.parentElement?.parentElement?.querySelectorAll(
                    "[data-carousel-dot]",
                );
            const slides = track?.children ? Array.from(track.children) : [];

            if (
                !track ||
                slides.length === 0 ||
                !prevBtn ||
                !nextBtn ||
                !dots ||
                dots.length === 0
            )
                return;

            let index = 0;
            let touchStartX = 0;
            let touchEndX = 0;

            const render = () => {
                track.style.transform = `translateX(-${index * 100}%)`;

                dots.forEach((dot, dotIndex) => {
                    const isActive = dotIndex === index;
                    dot.classList.toggle("w-8", isActive);
                    dot.classList.toggle("bg-emerald-200", isActive);
                    dot.classList.toggle("w-2", !isActive);
                    dot.classList.toggle("bg-emerald-200/45", !isActive);
                    dot.setAttribute(
                        "aria-current",
                        isActive ? "true" : "false",
                    );
                });
            };

            const prev = () => {
                index = index === 0 ? slides.length - 1 : index - 1;
                render();
            };

            const next = () => {
                index = index === slides.length - 1 ? 0 : index + 1;
                render();
            };

            prevBtn.addEventListener("click", prev);
            nextBtn.addEventListener("click", next);

            dots.forEach((dot) => {
                dot.addEventListener("click", () => {
                    const dotIndex = Number(dot.getAttribute("data-dot-index"));
                    if (Number.isNaN(dotIndex)) return;
                    index = dotIndex;
                    render();
                });
            });

            carousel.addEventListener("touchstart", (event) => {
                touchStartX = event.changedTouches[0]?.clientX ?? 0;
            });

            carousel.addEventListener("touchend", (event) => {
                touchEndX = event.changedTouches[0]?.clientX ?? 0;
                const distance = touchEndX - touchStartX;

                if (Math.abs(distance) < 40) return;
                if (distance < 0) {
                    next();
                } else {
                    prev();
                }
            });

            render();
        })();
    </script>
</section>
