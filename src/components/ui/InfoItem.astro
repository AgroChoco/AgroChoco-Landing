---
import type { IconName } from "../../data/icons";
import Icon from "./Icon.astro";

interface Props {
  icon: IconName;
  label: string;
  value: string;
  tone?: "emerald" | "teal";
}

const { icon, label, value, tone = "emerald" } = Astro.props;

const toneClass =
  tone === "teal"
    ? "bg-teal-50 text-teal-600"
    : "bg-emerald-50 text-emerald-600";
---

<div class="flex min-w-0 items-center gap-4">
  <div
    class={[
      "w-12 h-12 rounded-full flex items-center justify-center",
      toneClass,
    ].join(" ")}
  >
    <Icon name={icon} className="h-6 w-6" />
  </div>
  <div class="min-w-0">
    <p class="text-sm font-medium break-words text-gray-500">{label}</p>
    <p class="font-semibold break-words text-gray-900">{value}</p>
  </div>
</div>
