---
interface Props {
    variant?: "brand-soft" | "light" | "outline";
    uppercase?: boolean;
    className?: string;
}

const {
    variant = "brand-soft",
    uppercase = false,
    className = "",
} = Astro.props;

const variantClassMap: Record<NonNullable<Props["variant"]>, string> = {
    "brand-soft":
        "bg-emerald-500/20 text-emerald-100 border border-emerald-400/30 backdrop-blur-sm",
    light: "bg-white text-emerald-700 border border-emerald-200",
    outline: "bg-transparent text-emerald-700 border border-emerald-300",
};

const classes = [
    "inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold",
    uppercase ? "tracking-wide uppercase" : "",
    variantClassMap[variant],
    className,
]
    .filter(Boolean)
    .join(" ");
---

<span class={classes}>
    <slot />
</span>
