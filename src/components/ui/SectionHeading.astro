---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  tone?: "light" | "dark" | "hero";
  className?: string;
}

const {
  eyebrow,
  title,
  description,
  align = "center",
  tone = "dark",
  className = "",
} = Astro.props;

const isCentered = align === "center";

const eyebrowClass =
  tone === "light"
    ? "text-emerald-300"
    : tone === "hero"
      ? "text-emerald-200"
      : "text-emerald-600";

const titleClass =
  tone === "light"
    ? "text-white"
    : tone === "hero"
      ? "bg-linear-to-r from-emerald-300 to-teal-200 bg-clip-text text-transparent"
      : "text-gray-900";

const descriptionClass =
  tone === "light"
    ? "text-emerald-100"
    : tone === "hero"
      ? "text-emerald-50/90"
      : "text-gray-600";

const dividerClass =
  tone === "hero"
    ? "bg-linear-to-r from-emerald-300 to-teal-200"
    : "bg-linear-to-r from-emerald-500 to-teal-500";
---

<div
  class={["mb-10 md:mb-16", isCentered ? "text-center" : "text-left", className]
    .filter(Boolean)
    .join(" ")}
>
  <h2
    class={[
      "font-bold tracking-wide uppercase text-sm mb-2",
      eyebrowClass,
    ].join(" ")}
  >
    {eyebrow}
  </h2>
  <h3
    class={[
      "font-display text-2xl sm:text-3xl md:text-4xl font-extrabold leading-tight",
      titleClass,
    ].join(" ")}
  >
    {title}
  </h3>
  <div
    class={[
      "w-24 h-1 mt-6 rounded-full",
      dividerClass,
      isCentered ? "mx-auto" : "mx-0",
    ].join(" ")}
  >
  </div>
  {
    description && (
      <p
        class={[
          "mt-4 max-w-2xl text-base md:mt-6 md:text-lg",
          descriptionClass,
          isCentered ? "mx-auto" : "mx-0",
        ].join(" ")}
      >
        {description}
      </p>
    )
  }
</div>
