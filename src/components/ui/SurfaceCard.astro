---
interface Props {
  tone?: "neutral" | "emerald" | "teal";
  hover?: "none" | "lift";
  className?: string;
}

const { tone = "neutral", hover = "none", className = "" } = Astro.props;

const toneClassMap: Record<NonNullable<Props["tone"]>, string> = {
  neutral: "bg-white border border-gray-100",
  emerald: "bg-emerald-50 border border-emerald-100",
  teal: "bg-teal-50 border border-teal-100",
};

const hoverClassMap: Record<NonNullable<Props["hover"]>, string> = {
  none: "",
  lift: "transition-all duration-300 hover:-translate-y-1 hover:shadow-md",
};

const classes = [
  "rounded-2xl overflow-hidden",
  toneClassMap[tone],
  hoverClassMap[hover],
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div class={classes}>
  <slot />
</div>
