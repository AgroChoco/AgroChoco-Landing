---
interface Props {
  label: string;
  value: string | number;
}

const { label, value } = Astro.props;
---

<div class="rounded-2xl border border-emerald-100/80 bg-white p-4 shadow-sm">
  <p class="text-xs font-semibold tracking-wide text-gray-500 uppercase">
    {label}
  </p>
  <p class="mt-2 text-sm font-semibold text-gray-900">{value}</p>
</div>
