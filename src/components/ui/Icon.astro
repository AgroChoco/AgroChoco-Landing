---
import type { IconName } from "../../data/icons";

import arrowLeft from "../../assets/icons/arrow-left.svg?raw";
import arrowUpRight from "../../assets/icons/arrow-up-right.svg?raw";
import chevronDown from "../../assets/icons/chevron-down.svg?raw";
import chevronRight from "../../assets/icons/chevron-right.svg?raw";
import mapPin from "../../assets/icons/map-pin.svg?raw";
import mail from "../../assets/icons/mail.svg?raw";
import phone from "../../assets/icons/phone.svg?raw";
import sprout from "../../assets/icons/sprout.svg?raw";
import dna from "../../assets/icons/dna.svg?raw";
import flaskConical from "../../assets/icons/flask-conical.svg?raw";
import tractor from "../../assets/icons/tractor.svg?raw";

interface Props {
  name: IconName;
  className?: string;
  title?: string;
}

const icons: Record<IconName, string> = {
  "arrow-left": arrowLeft,
  "arrow-up-right": arrowUpRight,
  "chevron-down": chevronDown,
  "chevron-right": chevronRight,
  "map-pin": mapPin,
  mail,
  phone,
  sprout,
  dna,
  "flask-conical": flaskConical,
  tractor,
};

const { name, className = "w-5 h-5", title } = Astro.props as Props;
const iconSvg = icons[name];
---

<span
  class={[
    "inline-flex shrink-0 items-center justify-center leading-none align-middle [&>svg]:block [&>svg]:w-full [&>svg]:h-full [&>svg]:stroke-current",
    className,
  ].join(" ")}
  aria-hidden={title ? undefined : "true"}
  aria-label={title}
  role={title ? "img" : undefined}
  set:html={iconSvg}
/>
