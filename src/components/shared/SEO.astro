---
import { Font } from "astro:assets";
import Logo from "@images/branding/agrochoco-logo.svg";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  type?: "website" | "article";
  locale?: string;
}

const {
  title = "AgroChoco",
  description = "Micropropagación in vitro, clonación de plantas, análisis de suelos y asesoría técnica agrícola con enfoque científico y resultados medibles.",
  image = "/AgroChoco.svg",
  noindex = false,
  type = "website",
  locale = "es_MX",
} = Astro.props as Props;

const site = Astro.site;
const imageUrl = new URL(image, site);

const seoTitle = title.includes("AgroChoco") ? title : `${title} | AgroChoco`;
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const faviconHref = typeof Logo === "string" ? Logo : Logo.src;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "AgroChoco",
  url: site,
  logo: imageUrl,
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "AgroChoco",
  url: site,
  inLanguage: "es-MX",
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{seoTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={robotsContent} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content="AgroChoco" />
<meta property="og:locale" content={locale} />
<meta property="og:title" content={seoTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl.toString()} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seoTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl.toString()} />

<meta name="theme-color" content="#064e3b" />
<link rel="icon" type="image/svg+xml" href={faviconHref} />
<link rel="shortcut icon" href={faviconHref} />
<link rel="apple-touch-icon" href={faviconHref} />

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(organizationSchema)}
/>
<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(websiteSchema)}
/>

<Font cssVariable="--font-jakarta" preload />
<Font cssVariable="--font-outfit" preload />
