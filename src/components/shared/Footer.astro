---
interface FooterLink {
  href: string;
  label: string;
}

interface Props {
  brandName?: string;
  location?: string;
  tagline?: string;
  links?: FooterLink[];
}

const {
  links = [
    { href: "#inicio", label: "Inicio" },
    { href: "#nosotros", label: "Nosotros" },
    { href: "#servicios", label: "Servicios" },
  ],
} = Astro.props;
---

<footer class="border-t border-gray-800 bg-gray-900 py-12 text-gray-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex items-center gap-2">
        <span class="text-2xl font-bold text-white">AgroChoco</span>
      </div>

      <div class="flex flex-wrap justify-center gap-4 text-sm sm:gap-6">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="transition-colors hover:text-emerald-400"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>

    <div
      class="mt-8 flex flex-col items-center justify-between border-t border-gray-800 pt-8 text-center text-sm md:flex-row md:text-left"
    >
      <p>
        &copy; {new Date().getFullYear()}
        AgroChoco - Biotecnología Vegetal. Tabasco, México.
      </p>
    </div>
  </div>
</footer>
