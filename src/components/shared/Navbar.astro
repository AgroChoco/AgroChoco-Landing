---
import { Image } from "astro:assets";
import Logo from "@images/branding/agrochoco-logo.svg";

interface NavLink {
  href: string;
  label: string;
}

interface Props {
  brandName?: string;
  links?: NavLink[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  links = [
    { href: "#inicio", label: "Inicio" },
    { href: "#nosotros", label: "Nosotros" },
    { href: "#productos", label: "Productos" },
    { href: "#servicios", label: "Servicios" },
  ],
  ctaLabel = "Contactar",
  ctaHref = "#contacto",
} = Astro.props;
---

<header
  class="fixed z-50 w-full border-b border-gray-100 bg-white/95 shadow-sm backdrop-blur-[10px]"
>
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between sm:h-20">
      <a href="/#inicio" class="flex items-center gap-2">
        <Image
          src={Logo}
          alt="AgroChoco Logo"
          class="h-10 w-10 sm:h-12 sm:w-12"
          loading="lazy"
          decoding="async"
        />
        <span
          class="bg-linear-to-r from-emerald-700 to-teal-600 bg-clip-text text-xl font-bold text-transparent sm:text-2xl"
        >
          AgroChoco
        </span>
      </a>

      <div class="hidden items-center space-x-8 md:flex">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="font-medium text-gray-600 transition-colors hover:text-emerald-600"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href={ctaHref}
          class="transform rounded-full bg-emerald-600 px-6 py-2.5 font-medium text-white shadow-md transition-all hover:scale-105 hover:bg-emerald-700"
        >
          {ctaLabel}
        </a>
      </div>

      <div class="flex items-center md:hidden">
        <details class="group">
          <summary
            class="cursor-pointer list-none p-2 text-gray-600 focus:outline-none"
            aria-label="Abrir menu de navegacion"
          >
            <span class="relative block h-7 w-7" aria-hidden="true">
              <span
                class="absolute top-1 left-0 h-0.5 w-7 rounded-full bg-current"
              ></span>
              <span
                class="absolute top-3 left-0 h-0.5 w-7 rounded-full bg-current"
              ></span>
              <span
                class="absolute top-5 left-0 h-0.5 w-7 rounded-full bg-current"
              ></span>
            </span>
          </summary>

          <div
            class="fixed inset-x-0 top-16 z-50 max-h-[calc(100vh-4rem)] overflow-y-auto border-y border-gray-100 bg-white shadow-lg sm:top-20 sm:max-h-[calc(100vh-5rem)] md:hidden"
          >
            <div class="mx-auto max-w-7xl space-y-2 px-4 py-3 sm:px-6 lg:px-8">
              {
                links.map((link) => (
                  <a
                    href={link.href}
                    class="block rounded-md px-3 py-3 font-medium text-gray-700 hover:bg-emerald-50"
                  >
                    {link.label}
                  </a>
                ))
              }
              <a
                href={ctaHref}
                class="block rounded-md px-3 py-3 font-bold text-emerald-600 hover:bg-emerald-50"
              >
                {ctaLabel}
              </a>
            </div>
          </div>
        </details>
      </div>
    </div>
  </nav>
</header>
