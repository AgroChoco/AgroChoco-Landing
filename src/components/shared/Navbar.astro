---
import { Image } from "astro:assets";
import Logo from "@images/branding/agrochoco-logo.svg";

interface NavLink {
    href: string;
    label: string;
}

interface Props {
    brandName?: string;
    links?: NavLink[];
    ctaLabel?: string;
    ctaHref?: string;
}

const {
    links = [
        { href: "#inicio", label: "Inicio" },
        { href: "#nosotros", label: "Nosotros" },
        { href: "#productos", label: "Productos" },
        { href: "#servicios", label: "Servicios" },
    ],
    ctaLabel = "Contactar",
    ctaHref = "#contacto",
} = Astro.props;
---

<header
    class="fixed w-full z-50 border-b border-gray-100 shadow-sm bg-white/95 backdrop-blur-[10px]"
>
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16 sm:h-20">
            <a href="/#inicio" class="flex items-center gap-2">
                <Image
                    src={Logo}
                    alt="AgroChoco Logo"
                    class="w-10 h-10 sm:w-12 sm:h-12"
                    loading="lazy"
                    decoding="async"
                />
                <span
                    class="font-bold text-xl sm:text-2xl bg-clip-text text-transparent bg-linear-to-r from-emerald-700 to-teal-600"
                >
                    AgroChoco
                </span>
            </a>

            <div class="hidden md:flex items-center space-x-8">
                {
                    links.map((link) => (
                        <a
                            href={link.href}
                            class="text-gray-600 hover:text-emerald-600 font-medium transition-colors"
                        >
                            {link.label}
                        </a>
                    ))
                }
                <a
                    href={ctaHref}
                    class="bg-emerald-600 text-white px-6 py-2.5 rounded-full font-medium hover:bg-emerald-700 transition-all transform hover:scale-105 shadow-md"
                >
                    {ctaLabel}
                </a>
            </div>

            <div class="md:hidden flex items-center">
                <details class="group">
                    <summary
                        class="list-none cursor-pointer text-gray-600 focus:outline-none p-2"
                        aria-label="Abrir menu de navegacion"
                    >
                        <span class="block w-7 h-7 relative" aria-hidden="true">
                            <span
                                class="absolute left-0 top-1 h-0.5 w-7 bg-current rounded-full"
                            ></span>
                            <span
                                class="absolute left-0 top-3 h-0.5 w-7 bg-current rounded-full"
                            ></span>
                            <span
                                class="absolute left-0 top-5 h-0.5 w-7 bg-current rounded-full"
                            ></span>
                        </span>
                    </summary>

                    <div
                        class="md:hidden fixed inset-x-0 top-16 sm:top-20 border-y border-gray-100 bg-white shadow-lg z-50 max-h-[calc(100vh-4rem)] sm:max-h-[calc(100vh-5rem)] overflow-y-auto"
                    >
                        <div
                            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 space-y-2"
                        >
                            {
                                links.map((link) => (
                                    <a
                                        href={link.href}
                                        class="block px-3 py-3 text-gray-700 hover:bg-emerald-50 rounded-md font-medium"
                                    >
                                        {link.label}
                                    </a>
                                ))
                            }
                            <a
                                href={ctaHref}
                                class="block px-3 py-3 text-emerald-600 font-bold hover:bg-emerald-50 rounded-md"
                            >
                                {ctaLabel}
                            </a>
                        </div>
                    </div>
                </details>
            </div>
        </div>
    </nav>
</header>
